{
  "name": "@alex/protocol",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./control": {
      "import": "./dist/control.js",
      "types": "./dist/control.d.ts"
    },
    "./audio": {
      "import": "./dist/audio.js",
      "types": "./dist/audio.d.ts"
    },
    "./render": {
      "import": "./dist/render.js",
      "types": "./dist/render.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src --ext .ts --max-warnings=0 || true",
    "test": "vitest run",
    "prepare": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.6.3",
    "vitest": "^1.5.3",
    "@types/node": "^20.11.30"
  }
}
